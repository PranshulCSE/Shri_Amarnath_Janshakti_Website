# MongoDB Connection
# For local development, use: mongodb://localhost:27017/sajssm
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/sajssm

# JWT Secret Key
# IMPORTANT: Change this to a secure random string in production!
# Example: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS and Frontend URLs
FRONTEND_URL=http://localhost:5173

# Optional: For Vercel deployment
# VERCEL=1
